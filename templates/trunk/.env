# Trunk template environment variables
export PUSHD_DEVTOOLS_TRUNK_TEMPLATE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PUSHD_DEVTOOLS_TRUNK_CONFIGS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.trunk/configs"
export PUSHD_DEVTOOLS_BUNDLE_GEMFILE="${PUSHD_DEVTOOLS_DIR}/runtimes/ruby/Gemfile"
export PUSHD_DEVTOOLS_PACKAGE_FILE="${PUSHD_DEVTOOLS_DIR}/runtimes/node/package.json" 
