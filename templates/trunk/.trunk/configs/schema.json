{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the project"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "The version of the project"
    },
    "settings": {
      "type": "object",
      "properties": {
        "featureFlags": {
          "type": "object",
          "properties": {
            "newUI": {
              "type": "boolean"
            },
            "betaFeatures": {
              "type": "boolean"
            }
          },
          "required": ["newUI", "betaFeatures"]
        },
        "api": {
          "type": "object",
          "properties": {
            "baseUrl": {
              "type": "string",
              "format": "uri"
            },
            "timeout": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": ["baseUrl", "timeout"]
        }
      },
      "required": ["featureFlags", "api"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "required": ["name", "version", "settings", "dependencies"]
}
