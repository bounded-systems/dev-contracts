{
  "rubyLsp.rubyExecutablePath": "/opt/asf/ruby/bin/ruby",
  "rubyLsp.bundleGemfile": "${env:PUSHD_DEVTOOLS_DIR}/config/Gemfile",
  "editor.defaultFormatter": "trunk.io",
  "editor.formatOnSave": false,
  "rubyLsp.enabledFeatures": {
    "documentHighlights": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "semanticHighlighting": true,
    "signatureHelp": true,
    "codeActions": true,
    "diagnostics": true,
    "documentLink": true,
    "selectionRanges": true,
    "completion": true,
    "codeLens": true,
    "definition": true,
    "workspaceSymbol": true,
    "typeHierarchy": true
  },
  "sorbet.enabled": true,
  "sorbet.lspConfigs": [
    {
      "id": "default",
      "name": "Sorbet",
      "description": "Launch Sorbet using bundle exec with ASF Ruby",
      "command": ["/opt/asf/ruby/bin/bundle", "exec", "srb", "tc", "--lsp"],
      "env": {
        "PUSHD_DEVTOOLS_BUNDLE_GEMFILE": "${env:PUSHD_DEVTOOLS_DIR}/config/Gemfile"
      }
    }
  ],
  "sorbet.selectedLspConfigId": "default",
  "trunk.addToolsToPath": true,
  "trunk.autoInit": false,
  "trunk.showPreexistingIssues": false,
  "trunk.showWhatsNewMessage": false,
  "[ruby]": {
    "editor.defaultFormatter": "trunk.io"
  },

  // JSON Schema Validation Settings
  "json.validate.enable": true,
  "json.schemaDownload.enable": true,

  // YAML Language Support
  "yaml.format.enable": true,
  "yaml.format.singleQuote": true,
  "yaml.format.bracketSpacing": true,
  "yaml.format.proseWrap": "preserve",
  "yaml.format.printWidth": 80,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.validate": true,
  "[yaml]": {
    "editor.defaultFormatter": "trunk.io",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "yaml.schemas": {
    "https://static.trunk.io/pub/trunk-yaml-schema.json": [
      "**/trunk.{yml,yaml}"
    ],
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.{yml,yaml}"
    ],
    "https://raw.githubusercontent.com/rubocop/rubocop/master/config/default.yml": [
      "**/*rubocop*.{yml,yaml}"
    ],
    "https://raw.githubusercontent.com/standardrb/standard/main/config/base.yml": [
      "**/*standard*.{yml,yaml}"
    ],
    "https://json.schemastore.org/yamllint.json": ["**/*yamllint*.{yml,yaml}"]
  },
  "[jsonc]": {
    "editor.defaultFormatter": "trunk.io",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  }
}
