{
  "extends": "prettier",
  "rules": {
    "prefer-double-quotes": true,
    "no-unused-variables": true,
    "no-undefined": true,
    "no-multiple-empty-lines": ["error", { "max": 1 }],
    "valid-typeof": true,
    "no-extra-semi": true,
    "no-extra-parens": true,
    "no-empty": true,
    "no-dupe-keys": true,
    "no-dupe-args": true,
    "no-duplicate-case": true,
    "no-unreachable": true,
    "no-unsafe-finally": true,
    "no-unsafe-negation": true,
    "use-isnan": true,
    "valid-jsdoc": true,
    "valid-typeof": true
  }
} 
