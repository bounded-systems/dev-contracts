{
  "rubyLsp.rubyExecutablePath": "${env:PUSHD_DEVTOOLS_DIR}/ruby/${env:PUSHD_DEVTOOLS_RBENV_VERSION}/bin/ruby",
  "rubyLsp.bundleGemfile": "${env:PUSHD_DEVTOOLS_DIR}/config/Gemfile",
  
  "editor.defaultFormatter": "trunk.io",
  "editor.formatOnSave": false,
  
  "rubyLsp.enabledFeatures": {
    "documentHighlights": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "semanticHighlighting": true,
    "signatureHelp": true,
    "codeActions": true,
    "diagnostics": true,
    "documentLink": true,
    "selectionRanges": true,
    "completion": true,
    "codeLens": true,
    "definition": true,
    "workspaceSymbol": true,
    "typeHierarchy": true
  },
  
  "sorbet.enabled": true,
  "sorbet.lspConfigs": [
    {
      "id": "default",
      "name": "Sorbet",
      "description": "Launch Sorbet using bundle exec with Ruby ${env:PUSHD_DEVTOOLS_RBENV_VERSION}",
      "command": ["${env:PUSHD_DEVTOOLS_DIR}/ruby/${env:PUSHD_DEVTOOLS_RBENV_VERSION}/bin/bundle", "exec", "srb", "tc", "--lsp"],
      "env": {
        "BUNDLE_GEMFILE": "${env:PUSHD_DEVTOOLS_DIR}/config/Gemfile",
        "RBENV_VERSION": "${env:PUSHD_DEVTOOLS_RBENV_VERSION}"
      }
    }
  ],
  "sorbet.selectedLspConfigId": "default",
  
  "trunk.addToolsToPath": true,
  "trunk.autoInit": false,
  "trunk.showPreexistingIssues": false,
  "trunk.showWhatsNewMessage": false,
  "[ruby]": {
    "editor.defaultFormatter": "trunk.io"
  },

  // JSON Schema Validation Settings
  "json.validate.enable": true,
  "json.schemaDownload.enable": true,
  
  // YAML Language Support
  "yaml.format.enable": true,
  "yaml.format.singleQuote": true,
  "yaml.format.bracketSpacing": true,
  "yaml.format.proseWrap": "preserve",
  "yaml.format.printWidth": 80,
  "yaml.hover": true,
  "yaml.completion": true,
  "yaml.validate": true,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "yaml.schemas": {
    "https://static.trunk.io/pub/trunk-yaml-schema.json": [".trunk/trunk.yaml"],
    "https://json.schemastore.org/github-workflow.json": [".github/workflows/*.yml", ".github/workflows/*.yaml"]
  }
}
