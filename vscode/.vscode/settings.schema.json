{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VS Code Settings Schema",
  "type": "object",
  "properties": {
    "rubyLsp.rubyExecutablePath": {
      "type": "string",
      "description": "Path to the Ruby executable used by Ruby LSP"
    },
    "rubyLsp.bundleGemfile": {
      "type": "string",
      "description": "Path to the Gemfile used by Ruby LSP"
    },
    "editor.defaultFormatter": {
      "type": "string",
      "description": "Default formatter for all files"
    },
    "editor.formatOnSave": {
      "type": "boolean",
      "description": "Format files on save"
    },
    "rubyLsp.enabledFeatures": {
      "type": "object",
      "properties": {
        "documentHighlights": { "type": "boolean" },
        "documentSymbols": { "type": "boolean" },
        "foldingRanges": { "type": "boolean" },
        "hover": { "type": "boolean" },
        "inlayHint": { "type": "boolean" },
        "onTypeFormatting": { "type": "boolean" },
        "semanticHighlighting": { "type": "boolean" },
        "signatureHelp": { "type": "boolean" },
        "codeActions": { "type": "boolean" },
        "diagnostics": { "type": "boolean" },
        "documentLink": { "type": "boolean" },
        "selectionRanges": { "type": "boolean" },
        "completion": { "type": "boolean" },
        "codeLens": { "type": "boolean" },
        "definition": { "type": "boolean" },
        "workspaceSymbol": { "type": "boolean" },
        "typeHierarchy": { "type": "boolean" }
      }
    },
    "sorbet.enabled": {
      "type": "boolean",
      "description": "Enable Sorbet type checking"
    },
    "sorbet.lspConfigs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "command": { 
            "type": "array",
            "items": { "type": "string" }
          },
          "env": {
            "type": "object",
            "properties": {
              "BUNDLE_GEMFILE": { "type": "string" },
              "RBENV_VERSION": { "type": "string" }
            }
          }
        }
      }
    },
    "sorbet.selectedLspConfigId": {
      "type": "string",
      "description": "Selected Sorbet LSP configuration ID"
    },
    "trunk.addToolsToPath": {
      "type": "boolean",
      "description": "Add Trunk tools to PATH"
    },
    "trunk.autoInit": {
      "type": "boolean",
      "description": "Auto-initialize Trunk"
    },
    "trunk.showPreexistingIssues": {
      "type": "boolean",
      "description": "Show pre-existing issues in Trunk"
    },
    "trunk.showWhatsNewMessage": {
      "type": "boolean",
      "description": "Show what's new message in Trunk"
    },
    "[ruby]": {
      "type": "object",
      "properties": {
        "editor.defaultFormatter": {
          "type": "string",
          "description": "Default formatter for Ruby files"
        }
      }
    }
  }
} 
