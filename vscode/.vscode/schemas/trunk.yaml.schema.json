{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trunk Configuration",
  "description": "Schema for trunk.yaml configuration file",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string",
      "description": "The version of the trunk.yaml format",
      "pattern": "^\\d+\\.\\d+$"
    },
    "cli": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "The version of the Trunk CLI"
        }
      }
    },
    "lint": {
      "type": "object",
      "properties": {
        "ignore": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "linters": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "enabled": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disabled": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disabled": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtimes": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "plugins": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "uri"],
            "properties": {
              "id": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
} 
