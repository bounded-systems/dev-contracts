{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contracts Schema",
  "description": "Schema for defining the contracts.toml file structure",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "description": "Path to the JSON schema file for validation."
    },
    "quality": {
      "type": "object",
      "properties": {
        "lint": {
          "type": "object",
          "description": "Linting configurations, keyed by linter name.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "depends": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Dependencies for the linter, e.g., 'trunk'."
              },
              "version": {
                "type": "string",
                "description": "Specific version of the linter."
              }
            },
            "required": ["depends"],
            "additionalProperties": false
          }
        }
      },
      "required": ["lint"],
      "additionalProperties": false
    },
    "external_files": {
      "type": "object",
      "properties": {
        "setup": { "type": "string" },
        "roadmap": { "type": "string" }
      }
    },
    "definitions": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "provides": { "type": "array", "items": { "type": "string" } },
              "expects": { "type": "array", "items": { "type": "string" } },
              "guarantees": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id", "title", "provides", "expects", "guarantees"]
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "structure": {
          "type": "object",
          "properties": {
            "allow_empty_directory": { "type": "boolean" }
          },
          "required": ["allow_empty_directory"],
          "additionalProperties": false
        }
      },
      "required": ["structure"],
      "additionalProperties": false
    },
    "structure": {
      "type": "object",
      "description": "Repository structure contracts. Keys are file/directory paths.",
      "additionalProperties": {
        "$ref": "#/$defs/StructureValue"
      }
    }
  },
  "required": ["schema", "quality", "rules", "structure"],
  "additionalProperties": false,
  "$defs": {
    "StructureEntry": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file", "directory", "symlink"]
        },
        "purpose": { "type": "string" },
        "description": { "type": "string" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affects": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ignores": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["git", "contract"]
          }
        },
        "ignore_patterns": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "schema": {
          "type": "string",
          "description": "Reference to a schema definition (URL, path, or ref)."
        },
        "schema_ref": {
          "type": "string",
          "description": "Reference to a key defined in the top-level [schemas] table."
        },
        "types": {
          "type": "string",
          "description": "Reference to a type definition file (URL, path, or ref)."
        }
      },
      "additionalProperties": false
    },
    "DescriptionEntry": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "GlobalEntry": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" },
        "ignore_patterns": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "StructureValue": {
      "description": "Defines the allowed value types for entries under the 'structure' key.",
      "oneOf": [
        { "$ref": "#/$defs/StructureEntry" },
        { "$ref": "#/$defs/DescriptionEntry" },
        { "$ref": "#/$defs/GlobalEntry" },
        { "type": "object", "maxProperties": 0 },
        { "type": "string" }
      ]
    }
  }
}
