{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "README Schema",
  "description": "Schema for defining README content structure",
  "type": "object",
  "required": ["project", "contracts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "problem_statement": { "type": "string" },
        "solution": { "type": "string" }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "provides", "expects", "guarantees"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "provides": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "guarantees": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "setup": {
      "type": "object",
      "properties": {
        "prerequisites": {
          "type": "object",
          "properties": {
            "devtools": {
              "type": "array",
              "items": { "type": "string" }
            },
            "target_projects": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "installation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step"],
            "properties": {
              "step": { "type": "string" },
              "code": { "type": "string" },
              "detail": { "type": "string" },
              "gitignore": { "type": "string" }
            }
          }
        }
      }
    },
    "configuration": {
      "type": "object"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "command", "description"],
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "ide_integration": {
      "type": "object"
    },
    "structure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/properties/structure/items" }
          }
        }
      }
    },
    "roadmap": {
      "type": "object",
      "properties": {
        "immediate_priorities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "future_enhancements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
