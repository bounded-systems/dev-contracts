{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contracts Schema",
  "description": "Schema for defining the contracts.toml file structure",
  "type": "object",
  "properties": {
    "structure": {
      "type": "object",
      "description": "Repository structure contracts",
      "required": [],
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "purpose"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["file", "directory", "symlink"]
              },
              "purpose": { "type": "string" },
              "description": { "type": "string" },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" }
              },
              "affects": {
                "type": "array",
                "items": { "type": "string" }
              },
              "ignores": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["git", "contract"]
                }
              },
              "ignore_patterns": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["description"],
            "properties": {
              "description": { "type": "string" }
            }
          },
          {
            "type": "string"
          }
        ]
      },
      "patternProperties": {
        "^.+$": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    }
  }
}
