# Set the project root directory
export PUSHD_DEVTOOLS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Define template and runtime directories relative to project root
export PUSHD_DEVTOOLS_TEMPLATES_DIR="${PUSHD_DEVTOOLS_DIR}/templates"
export PUSHD_DEVTOOLS_RUNTIMES_DIR="${PUSHD_DEVTOOLS_DIR}/runtimes"

# Source all template environment files
if [ -f "${PUSHD_DEVTOOLS_TEMPLATES_DIR}/.env" ]; then
  source "${PUSHD_DEVTOOLS_TEMPLATES_DIR}/.env"
fi

# Source all runtime environment files
if [ -f "${PUSHD_DEVTOOLS_RUNTIMES_DIR}/.env" ]; then
  source "${PUSHD_DEVTOOLS_RUNTIMES_DIR}/.env"
fi
