# Set the project root directory
export PUSHD_DEVTOOLS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Define template and runtime directories relative to project root
export PUSHD_DEVTOOLS_TEMPLATES_DIR="${PUSHD_DEVTOOLS_DIR}/templates"
export PUSHD_DEVTOOLS_RUNTIMES_DIR="${PUSHD_DEVTOOLS_DIR}/runtimes"

# Export the current environment level
export PUSHD_ENV_LEVEL="root"

# Function to source child environment files
source_child_env() {
  local child_dir="$1"
  if [ -f "${child_dir}/.env" ]; then
    # Set parent directory for child context
    export PUSHD_PARENT_DIR="${PUSHD_DEVTOOLS_DIR}"
    # Source the child environment file
    source "${child_dir}/.env"
    # Clear parent directory after sourcing
    unset PUSHD_PARENT_DIR
  fi
}

# Source template environments
source_child_env "${PUSHD_DEVTOOLS_TEMPLATES_DIR}"
