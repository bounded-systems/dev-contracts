# Set the project root directory
export PUSHD_DEVTOOLS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Source all template environment files
if [ -f "${PUSHD_DEVTOOLS_DIR}/templates/.env" ]; then
  source "${PUSHD_DEVTOOLS_DIR}/templates/.env"
fi

# Source all runtime environment files
if [ -f "${PUSHD_DEVTOOLS_DIR}/runtimes/.env" ]; then
  source "${PUSHD_DEVTOOLS_DIR}/runtimes/.env"
fi
